---
import ArticleBody from "./ArticleBody.astro";
import ArticleFooter from "./ArticleFooter.astro";
import ArticleHeader from "./ArticleHeader.astro";
import Breadcrumb from "./Breadcrumb.astro";

interface Props {
  post: any;
  sectionLabel: string;
  listHref: string;
  previousPost?: any;
  nextPost?: any;
}

const { post, sectionLabel, listHref, previousPost, nextPost } = Astro.props;
---

<article class="article-page">
  <div class="container">
    <div class="article-shell">
      <Breadcrumb
        items={[
          { label: "홈", href: import.meta.env.BASE_URL },
          { label: sectionLabel, href: listHref },
          { label: post.data.title }
        ]}
      />

      <ArticleHeader post={post} />

      <ArticleBody>
        <slot />
      </ArticleBody>

      <ArticleFooter
        tags={post.data.tags}
        listHref={listHref}
        previousPost={previousPost}
        nextPost={nextPost}
      />
    </div>
  </div>
</article>
