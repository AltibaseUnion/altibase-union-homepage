---
import { siteConfig } from "../data/site";
import { Bell, ClipboardList, Home, MessageCircle, MessagesSquare, ShieldQuestion, Youtube } from "lucide";

const iconMap: Record<string, any> = {
  bell: Bell,
  "clipboard-list": ClipboardList,
  home: Home,
  "message-circle": MessageCircle,
  "messages-square": MessagesSquare,
  "shield-question": ShieldQuestion,
  youtube: Youtube
};

const attrsToString = (attrs: Record<string, any>) =>
  Object.entries(attrs)
    .map(([key, value]) => `${key}="${String(value)}"`)
    .join(" ");

const renderNode = (node: any): string => {
  const [tag, attrs, children = []] = node;
  return `<${tag} ${attrsToString(attrs)}>${children.map(renderNode).join("")}</${tag}>`;
};

const renderIcon = (name: string) => {
  const icon = iconMap[name] || MessageCircle;
  const [tag, attrs, children] = icon;
  return renderNode([
    tag,
    {
      ...attrs,
      class: "quick-link-svg",
      "aria-hidden": "true",
      focusable: "false"
    },
    children
  ]);
};
---

<section id="quickLinks" class="quick-section" aria-labelledby="quickLinksHeading">
  <div class="panel-heading">
    <div>
      <h3 id="quickLinksHeading">바로가기</h3>
    </div>
  </div>
  <div class="quick-links-grid">
    {siteConfig.quickLinks.map((link) => (
      <a class="quick-link-card" href={link.url} target="_blank" rel="noopener noreferrer">
        <span class="icon-box" set:html={renderIcon(link.icon)} />
        <span>
          <h4>{link.title}</h4>
          <p>새 창에서 바로가기</p>
        </span>
      </a>
    ))}
  </div>
</section>
