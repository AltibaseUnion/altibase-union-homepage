---
import { siteConfig } from "../data/site";
---

<section id="quickLinks" class="quick-section" aria-labelledby="quickLinksHeading">
  <div class="panel-heading">
    <div>
      <h3 id="quickLinksHeading">바로가기</h3>
    </div>
  </div>
  <div class="quick-links-grid">
    {siteConfig.quickLinks.map((link) => (
      <a class="quick-link-card" href={link.url} target="_blank" rel="noopener noreferrer">
        <span class="icon-box"><i data-lucide={link.icon} aria-hidden="true"></i></span>
        <span>
          <h4>{link.title}</h4>
          <p>새 창에서 바로가기</p>
        </span>
      </a>
    ))}
  </div>
</section>
