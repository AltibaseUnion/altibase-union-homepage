---
import { formatDate } from "../data/site";

interface Props {
  title: string;
  posts: any[];
  href: string;
  type: string;
}

const { title, posts, href, type } = Astro.props;
---

<section class="section-panel" aria-labelledby={`${type}Heading`}>
  <div class="panel-heading">
    <div>
      <h3 id={`${type}Heading`}>{title}</h3>
    </div>
    <a class="panel-more-link" href={href} aria-label={`${title} 전체보기`}>
      전체보기 <span aria-hidden="true">→</span>
    </a>
  </div>
  <div class="post-list">
    {posts.map((post) => (
      <a class="post-item" href={post.url}>
        <p class="post-title">{post.data.title}</p>
        <div class="post-meta">
          <span>{post.data.category}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        </div>
      </a>
    ))}
  </div>
</section>
