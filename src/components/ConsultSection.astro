---
import { siteConfig } from "../data/site";
---

<section id="contact" class="contact-band">
  <div class="container">
    <div class="contact-band-inner">
      <div>
        <h2>상담 및 제보</h2>
        <p>노동조건, 조직문화, 제도 개선 등 조합과 논의하고 싶은 내용을 안전하게 접수합니다.</p>
      </div>
      <a class="btn btn-primary" href={siteConfig.consultFormUrl} target="_blank" rel="noopener noreferrer">
        <i data-lucide="message-circle" aria-hidden="true"></i>
        상담 및 제보하기
      </a>
    </div>
  </div>
</section>
