---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleLayout from "../../components/ArticleLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("notices", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <ArticleLayout post={post} sectionLabel="NOTICE" listHref={`${import.meta.env.BASE_URL}notices/`}>
    <Content />
  </ArticleLayout>
</BaseLayout>
