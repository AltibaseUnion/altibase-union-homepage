---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortPosts } from "../../data/site";

const posts = sortPosts(await getCollection("notices", ({ data }) => !data.draft));
---

<BaseLayout title="공지사항" description="Altibase 노동조합 공지사항 목록">
  <section class="page-header">
    <div class="container">
      <h1>공지사항</h1>
      <p>조합원에게 필요한 주요 안내와 운영 소식을 확인할 수 있습니다.</p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container">
      <div class="content-list">
        {posts.map((post) => (
          <a class="content-card" href={`${import.meta.env.BASE_URL}notices/${post.data.slug}/`}>
            <div>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
              <div class="content-meta">
                <span>{post.data.category}</span>
                <span aria-hidden="true">·</span>
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
