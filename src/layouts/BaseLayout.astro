---
import "../styles/global.css";
import { siteConfig } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;
const pageTitle = Astro.props.title ? `${Astro.props.title} | ${siteConfig.title}` : siteConfig.title;
const description = Astro.props.description || siteConfig.description;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}images/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" href={`${base}images/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}images/favicon.png`} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  </head>
  <body>
    <a class="skip-link" href="#mainContent">본문 바로가기</a>

    <nav class="navbar navbar-expand-lg fixed-top bg-white border-bottom" aria-label="주요 메뉴">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" href={base} aria-label="Altibase Union 홈">
          <img class="brand-symbol" src={`${base}images/logo-symbol.png`} alt="" />
          <span>Altibase Union</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="메뉴 열기">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavigation">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link" href={base}>홈</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}notices/`}>공지사항</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}activities/`}>활동보고</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}#quickLinks`}>바로가기</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}#contact`}>상담·제보</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <main id="mainContent">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="row g-3 align-items-center">
          <div class="col-lg-6">
            <strong>Altibase Union</strong>
            <p class="mb-0">조합원의 권익 보호와 투명한 소통을 위한 공식 홈페이지입니다.</p>
            <p class="mb-0">
              <a class="footer-email" href={`mailto:${siteConfig.email}`}>
                <i data-lucide="mail" aria-hidden="true"></i>
                {siteConfig.email}
              </a>
            </p>
          </div>
          <div class="col-lg-6 text-lg-end">
            <p class="mb-0 small text-white-50">Copyright © {new Date().getFullYear()} Altibase Union. All rights reserved.</p>
          </div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      });
    </script>
  </body>
</html>
